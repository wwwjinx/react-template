{
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.oxc": "explicit",
    "source.organizeImports": "never",
  },
  "[json][jsonc]": {
    "editor.formatOnSave": true, // 避免与其他格式化工具冲突
  },
  "oxc.enable.oxfmt": false
}
